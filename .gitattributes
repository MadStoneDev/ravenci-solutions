# Normalise line endings to LF for all text files, regardless of the
# editor/OS that saved them. Stops CRLF<->LF churn on WSL/Windows.
* text=auto eol=lf

# Treat known binaries as binary so they're never line-ending normalised.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp4 binary
*.webm binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
